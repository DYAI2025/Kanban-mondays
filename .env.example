# VITE_GEMINI_API_KEY: Required for Gemini AI API calls in the Vite frontend.
# For Railway, set this variable in the project "Variables" tab.
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional fallback (used if present in server-like runtimes).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public URL where this app is hosted.
APP_URL="https://your-railway-domain.up.railway.app"
